  }));
  if(trendChartInst)trendChartInst.destroy();
  const ctx=document.getElementById('trendChart').getContext('2d');
  trendChartInst=new Chart(ctx,{
    type:'line',data:{labels,datasets},
    options:{responsive:true,scales:{y:{min:0,max:2,ticks:{stepSize:.5}},x:{ticks:{font:{size:11}}}},
    plugins:{legend:{position:'bottom'},title:{display:true,text:'관찰 회차별 발달축 평균 점수 추이',font:{size:13,weight:'600'},padding:{bottom:12}}}}
  });
  const row=document.getElementById('trendRadarRow');row.innerHTML='';
  rows.forEach(obs=>{
