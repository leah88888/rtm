        const cls = v===2 ? 'preview-score-2' : v===1 ? 'preview-score-1' : 'preview-score-0';
        return `<td class="${cls}">${v}</td>`;
      }).join('');
      return `<tr><td class="axis-cell">${ax.name}</td>${cells}</tr>`;
    }).join('');

    item.innerHTML=`
      <div style="width:100%;">
        <div class="history-item-top">
          <div class="history-date">${obs.observed_at}</div>
          <div class="history-teacher">${obs.teacher_name||'—'}</div>
          <div class="history-axes">${badges}</div>
          <div class="history-actions">
