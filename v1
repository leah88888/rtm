<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>셀프인지모니터링 · 교사용</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --bg:#F6F7F9; --surface:#fff; --border:#E4E7EC;
  --text-primary:#111318; --text-secondary:#4B5563; --text-muted:#9CA3AF;
  --accent:#00ac00; --accent-light:#E8F8E8; --accent-dark:#008800;
  --warm:#E07B2A; --warm-light:#FEF3E7;
  --score-0:#F3F4F6; --score-0-text:#9CA3AF;
  --score-1-bg:#E8F8E8; --score-1-text:#006600;
  --score-2-bg:#00ac00; --score-2-text:#fff;
  --danger:#DC2626; --danger-light:#FEF2F2;
  --sidebar:220px;
  --radius:10px; --shadow:0 1px 6px rgba(0,0,0,.06); --shadow-lg:0 6px 28px rgba(0,0,0,.09);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Noto Sans KR',sans-serif;background:var(--bg);color:var(--text-primary);min-height:100vh;font-size:14px;line-height:1.65;}

/* ── Login ── */
.login-gate{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:9999;}
.login-box{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:44px 38px;width:340px;box-shadow:var(--shadow-lg);text-align:center;}
.login-icon{font-size:30px;margin-bottom:14px;}
.login-title{font-size:17px;font-weight:600;margin-bottom:4px;}
.login-sub{font-size:12px;color:var(--text-muted);margin-bottom:26px;line-height:1.6;}
.login-input{width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:15px;font-family:'Noto Sans KR',sans-serif;color:var(--text-primary);background:var(--bg);text-align:center;letter-spacing:.15em;margin-bottom:12px;display:block;transition:border-color .15s;}
.login-input:focus{outline:none;border-color:var(--accent);background:#fff;}
.login-btn{width:100%;padding:11px;background:var(--accent);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;font-family:'Noto Sans KR',sans-serif;}
.login-btn:hover{background:var(--accent-dark);}
.login-error{font-size:12px;color:var(--danger);margin-top:10px;min-height:18px;}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-8px)}75%{transform:translateX(8px)}}
.app-wrap{display:none;}
.app-wrap.unlocked{display:flex;flex-direction:column;min-height:100vh;}

/* ── Top header ── */
.header{background:var(--surface);border-bottom:1px solid var(--border);padding:13px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;box-shadow:var(--shadow);}
.header-title{font-size:16px;font-weight:600;letter-spacing:-.02em;}
.header-title span{color:var(--accent);}
.header-subtitle{font-size:11px;color:var(--text-muted);margin-top:1px;}

/* ── Child bar (below header) ── */
.child-bar{background:var(--surface);border-bottom:1px solid var(--border);padding:10px 24px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.child-bar-label{font-size:10px;font-weight:700;color:var(--text-muted);letter-spacing:.08em;text-transform:uppercase;flex-shrink:0;}
.child-select{border:1.5px solid var(--border);border-radius:7px;padding:6px 10px;font-size:13px;font-family:'Noto Sans KR',sans-serif;color:var(--text-primary);background:var(--bg);min-width:150px;max-width:240px;}
.child-select:focus{outline:none;border-color:var(--accent);background:#fff;}
.child-status{font-size:13px;font-weight:600;color:var(--text-muted);margin-left:auto;}
.child-status.saved{color:var(--accent);font-size:14px;}

/* ── App body: sidebar + main ── */
.app-body{display:flex;flex:1;}

/* ── Sidebar ── */
.sidebar{width:var(--sidebar);flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:sticky;top:89px;height:calc(100vh - 89px);overflow-y:auto;}
.sidebar-section{padding:18px 14px 6px;}
.sidebar-section-label{font-size:10px;font-weight:700;color:var(--text-muted);letter-spacing:.1em;text-transform:uppercase;padding:0 6px;margin-bottom:6px;}
.sidebar-menu-group{background:var(--bg);border:1px solid var(--border);border-radius:9px;overflow:hidden;margin-bottom:4px;}
.sidebar-group-title{font-size:11px;font-weight:700;color:var(--text-secondary);padding:9px 12px 4px;border-bottom:1px solid var(--border);background:#f0f2f5;display:flex;align-items:center;gap:6px;}
.sidebar-group-title svg{width:13px;height:13px;flex-shrink:0;}
.nav-item{display:flex;align-items:center;gap:8px;padding:8px 12px;font-size:13px;font-weight:500;color:var(--text-secondary);cursor:pointer;border:none;background:none;width:100%;text-align:left;font-family:'Noto Sans KR',sans-serif;transition:background .12s,color .12s;border-bottom:1px solid var(--border);}
.nav-item:last-child{border-bottom:none;}
.nav-item:hover{background:var(--accent-light);color:var(--accent-dark);}
.nav-item.active{background:var(--accent-light);color:var(--accent-dark);font-weight:600;}
.nav-item .nav-num{font-size:10px;font-weight:700;color:var(--text-muted);min-width:16px;}
.nav-item.active .nav-num{color:var(--accent);}

/* ── Main content ── */
.main{flex:1;padding:22px 24px;min-width:0;overflow-x:hidden;}

/* ── Sub-tabs (inside input/report group) ── */
.subtab-wrap{display:flex;border-bottom:1.5px solid var(--border);margin-bottom:18px;overflow-x:auto;}
.subtab-btn{padding:8px 16px;font-size:13px;font-weight:500;color:var(--text-muted);background:none;border:none;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1.5px;transition:color .13s;font-family:'Noto Sans KR',sans-serif;white-space:nowrap;}
.subtab-btn.active{color:var(--text-primary);border-bottom-color:var(--accent);font-weight:600;}
.subtab-content{display:none;}
.subtab-content.active{display:block;}

/* ── Page panels ── */
.page-panel{display:none;}
.page-panel.active{display:block;}

/* ── Section title ── */
.section-title{font-size:14px;font-weight:600;color:var(--text-primary);margin-bottom:13px;display:flex;align-items:center;gap:7px;}
.section-title::before{content:'';width:3px;height:16px;background:var(--accent);border-radius:2px;}

/* ── Buttons ── */
.btn{padding:7px 15px;border-radius:7px;font-size:13px;font-weight:500;cursor:pointer;border:none;transition:all .13s;font-family:'Noto Sans KR',sans-serif;}
.btn-primary{background:var(--accent);color:#fff;}
.btn-primary:hover{background:var(--accent-dark);}
.btn-secondary{background:var(--surface);color:var(--text-primary);border:1.5px solid var(--border);}
.btn-secondary:hover{border-color:var(--accent);color:var(--accent);}
.btn-dark{background:var(--text-primary);color:#fff;}
.btn-dark:hover{background:#2d3748;}
.btn-ghost{background:transparent;color:var(--text-muted);border:1.5px solid var(--border);}
.btn-ghost:hover{color:var(--text-secondary);border-color:#9CA3AF;}
.btn-danger{background:var(--danger);color:#fff;}
.btn-danger:hover{background:#b91c1c;}
.btn-sm{padding:5px 11px;font-size:12px;}
.btn-save{background:var(--accent);color:#fff;display:flex;align-items:center;gap:5px;}
.btn-save:hover{background:var(--accent-dark);}

/* ── Student card ── */
.student-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;margin-bottom:16px;box-shadow:var(--shadow);display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.field-group{display:flex;flex-direction:column;gap:4px;}
.field-label{font-size:10px;font-weight:600;color:var(--text-muted);letter-spacing:.08em;text-transform:uppercase;}
.field-input{border:1.5px solid var(--border);border-radius:7px;padding:7px 10px;font-size:13px;font-family:'Noto Sans KR',sans-serif;color:var(--text-primary);background:var(--bg);transition:border-color .13s;}
.field-input:focus{outline:none;border-color:var(--accent);background:#fff;}

/* ── Score table ── */
.score-table-wrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);margin-bottom:16px;}
.score-table{width:100%;border-collapse:collapse;}
.score-table th{padding:10px 13px;font-size:12px;font-weight:600;color:var(--text-secondary);background:#FAFBFC;border-bottom:1px solid var(--border);text-align:center;}
.score-table th.axis-header{text-align:left;width:145px;}
.score-table td{padding:10px 13px;border-bottom:1px solid var(--border);text-align:center;}
.score-table tr:last-child td{border-bottom:none;}
.score-table tr:hover td{background:#FAFBFC;}
.axis-name{font-weight:600;color:var(--text-primary);font-size:13px;}
.axis-desc{font-size:11px;color:var(--text-muted);}
.score-btn-group{display:flex;gap:4px;justify-content:center;}
.score-btn{width:34px;height:34px;border-radius:7px;border:1.5px solid var(--border);background:var(--score-0);color:var(--score-0-text);font-size:14px;font-weight:600;cursor:pointer;transition:all .12s;display:flex;align-items:center;justify-content:center;font-family:'Noto Sans KR',sans-serif;}
.score-btn:hover{border-color:var(--accent);transform:scale(1.06);}
.score-btn.active-0{background:var(--score-0);border-color:#9CA3AF;box-shadow:0 0 0 2px rgba(156,163,175,.2);}
.score-btn.active-1{background:var(--score-1-bg);border-color:#009000;color:var(--score-1-text);box-shadow:0 0 0 2px rgba(0,172,0,.15);}
.score-btn.active-2{background:var(--score-2-bg);border-color:var(--accent-dark);color:var(--score-2-text);box-shadow:0 0 0 2px rgba(0,172,0,.3);}
.input-complete-bar{height:3px;background:var(--border);border-radius:2px;margin-bottom:13px;overflow:hidden;}
.input-complete-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .28s;width:0%;}

/* ── Analysis ── */
.analysis-panel{display:none;animation:fadeUp .28s ease forwards;}
.analysis-panel.visible{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.analysis-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:18px;}
.summary-card{background:var(--accent);border-radius:var(--radius);padding:18px 22px;margin-bottom:16px;position:relative;overflow:hidden;}
.summary-card::after{content:'';position:absolute;top:-24px;right:-24px;width:110px;height:110px;border-radius:50%;background:rgba(255,255,255,.08);}
.summary-label{font-size:10px;font-weight:600;letter-spacing:.1em;color:rgba(255,255,255,.6);margin-bottom:6px;text-transform:uppercase;}
.summary-text{font-size:15px;color:#fff;line-height:1.75;font-weight:600;position:relative;z-index:1;}
.analysis-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;box-shadow:var(--shadow);}
.analysis-card-title{font-size:11px;font-weight:600;letter-spacing:.06em;color:var(--text-muted);text-transform:uppercase;margin-bottom:12px;}
.axis-result-row{border:1px solid var(--border);border-radius:9px;padding:12px 13px;margin-bottom:8px;background:var(--surface);}
.axis-result-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.axis-result-name{font-weight:600;font-size:14px;}
.axis-badges{display:flex;gap:4px;}
.badge{padding:2px 8px;border-radius:20px;font-size:11px;font-weight:600;}
.badge-strong{background:var(--accent-light);color:var(--accent-dark);}
.badge-developing{background:#FEF3E7;color:#B45309;}
.badge-support{background:var(--danger-light);color:var(--danger);}
.badge-stable{background:#F3F4F6;color:var(--text-secondary);}
.badge-variable{background:#FEF3E7;color:#B45309;}
.axis-auto-text{font-size:13px;color:var(--text-secondary);line-height:1.7;padding:7px 10px;background:var(--bg);border-radius:7px;margin-bottom:7px;border-left:2.5px solid var(--accent);}
.teacher-input{width:100%;padding:7px 10px;border:1.5px dashed var(--border);border-radius:7px;font-size:13px;font-family:'Noto Sans KR',sans-serif;color:var(--text-primary);background:transparent;resize:none;min-height:38px;transition:all .13s;}
.teacher-input:focus{outline:none;border-color:var(--warm);background:var(--warm-light);border-style:solid;}
.teacher-input::placeholder{color:var(--text-muted);font-size:12px;}
.mini-bar-wrap{padding:1px 0;}
.mini-bar-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;}
.mini-bar-label{width:62px;font-size:11px;color:var(--text-secondary);text-align:right;flex-shrink:0;}
.mini-bar-track{flex:1;height:7px;background:var(--border);border-radius:4px;overflow:hidden;}
.mini-bar-fill{height:100%;border-radius:4px;transition:width .45s;}
.mini-bar-val{font-size:11px;font-weight:600;color:var(--text-secondary);width:26px;}
.radar-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:11px;margin-bottom:16px;width:100%;min-width:0;}
.radar-card{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:11px 8px 10px;text-align:center;box-shadow:var(--shadow);min-width:0;overflow:hidden;}
.radar-card svg{max-width:100%;height:auto;display:block;margin:0 auto;}
.radar-card-label{font-size:11px;font-weight:600;color:var(--text-secondary);margin-bottom:6px;}
.radar-type-tags{display:flex;flex-wrap:wrap;gap:3px;justify-content:center;margin-top:6px;}
.type-tag{background:#1A1A1A;color:#fff;padding:3px 7px;border-radius:20px;font-size:10px;font-weight:600;}
.parent-section{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);margin-bottom:16px;}
.parent-section-header{background:#FAFBFC;padding:10px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.parent-section-title{font-weight:600;color:var(--text-secondary);font-size:12px;letter-spacing:.04em;text-transform:uppercase;}
.parent-section-body{padding:13px 16px;}
.parent-sentence-display{font-size:13px;color:var(--text-secondary);line-height:1.8;padding:8px 12px;background:var(--bg);border-radius:7px;border-left:2.5px solid var(--accent);}

/* ── Edit tab ── */
.edit-section-wrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);margin-bottom:16px;}
.edit-section-header{padding:13px 18px;border-bottom:1px solid var(--border);}
.edit-section-header.warm-tint{background:var(--warm-light);}
.edit-section-header.blue-tint{background:#EFF6FF;}
.edit-section-header h3{font-size:14px;font-weight:600;}
.edit-section-header h3.warm{color:var(--warm);}
.edit-section-header h3.blue{color:#1D4ED8;}
.edit-section-header p{font-size:12px;color:var(--text-muted);margin-top:3px;}
.sentence-input{width:100%;padding:9px 13px;border:1.5px solid var(--border);border-radius:7px;font-size:13px;font-family:'Noto Sans KR',sans-serif;color:var(--text-primary);background:#fff;resize:vertical;min-height:60px;transition:border-color .13s;line-height:1.7;}
.sentence-input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 2.5px rgba(0,172,0,.12);}
.sentence-input::placeholder{color:var(--text-muted);font-size:12px;}

/* ── History ── */
.history-list{display:flex;flex-direction:column;gap:0;}
.history-item{background:var(--surface);border:1px solid var(--border);border-radius:0;padding:13px 16px;display:flex;align-items:flex-start;gap:12px;border-bottom:none;}
.history-item:first-child{border-radius:9px 9px 0 0;}
.history-item:last-child{border-radius:0 0 9px 9px;border-bottom:1px solid var(--border);}
.history-item:only-child{border-radius:9px;}
.history-item-top{display:flex;align-items:center;gap:12px;width:100%;}
.history-date{font-weight:600;font-size:13px;color:var(--text-primary);min-width:90px;}
.history-teacher{font-size:12px;color:var(--text-muted);}
.history-axes{display:flex;gap:4px;flex-wrap:wrap;flex:1;}
.history-actions{display:flex;gap:6px;flex-shrink:0;}
/* Expanded score preview */
.history-preview{display:block;padding:12px 0 2px;border-top:1px dashed var(--border);margin-top:10px;width:100%;}
.preview-table{width:100%;border-collapse:collapse;font-size:12px;}
.preview-table th{padding:5px 8px;background:#FAFBFC;color:var(--text-muted);font-weight:600;border:1px solid var(--border);text-align:center;}
.preview-table td{padding:5px 8px;border:1px solid var(--border);text-align:center;}
.preview-table td.axis-cell{text-align:left;font-weight:600;color:var(--text-primary);}
.preview-score-0{color:var(--score-0-text);}
.preview-score-1{color:var(--score-1-text);font-weight:700;}
.preview-score-2{color:var(--accent-dark);font-weight:700;}

/* ── Edit tracking ── */
.edit-track-bar{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:12px 16px;margin-bottom:14px;display:flex;align-items:center;gap:10px;display:none;}
.edit-track-bar.show{display:flex;}
.edit-track-label{font-size:12px;color:var(--text-secondary);flex:1;}
.edit-track-count{font-size:11px;font-weight:600;color:var(--warm);}

/* ── Compare ── */
.compare-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
.chart-wrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;box-shadow:var(--shadow);margin-bottom:16px;}
.chart-wrap canvas{max-height:300px;}
.no-child-msg{text-align:center;padding:40px 20px;color:var(--text-muted);}
.no-child-msg .icon{font-size:32px;margin-bottom:10px;}

/* ── Report ── */
.report-output{display:none;background:#fff;border:1px solid var(--border);border-radius:var(--radius);padding:36px;box-shadow:var(--shadow-lg);max-width:780px;margin:0 auto;}
.report-output.visible{display:block;animation:fadeUp .3s ease;}
.report-logo{font-size:10px;font-weight:600;letter-spacing:.12em;color:var(--text-muted);margin-bottom:16px;text-transform:uppercase;}
.report-main-title{font-size:20px;font-weight:600;color:var(--text-primary);margin-bottom:4px;}
.report-divider{width:30px;height:2.5px;background:var(--accent);border-radius:2px;margin:12px 0;}
.brain-block{background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:15px 17px;margin-top:16px;border-left:3px solid var(--accent);}
.brain-block-title{font-size:13px;font-weight:600;color:var(--text-primary);margin-bottom:7px;}
.brain-block-text{font-size:13px;color:var(--text-secondary);line-height:1.85;}

/* ── Modal ── */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;z-index:500;}
.modal-box{background:#fff;border-radius:12px;padding:26px;width:360px;box-shadow:var(--shadow-lg);}
.modal-title{font-size:15px;font-weight:600;margin-bottom:14px;}
.modal-input{width:100%;padding:8px 11px;border:1.5px solid var(--border);border-radius:7px;font-size:13px;font-family:'Noto Sans KR',sans-serif;margin-bottom:9px;transition:border-color .13s;}
.modal-input:focus{outline:none;border-color:var(--accent);}
.modal-btns{display:flex;gap:8px;justify-content:flex-end;margin-top:14px;}

/* ── Toast ── */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1A1A1A;color:#fff;padding:9px 18px;border-radius:8px;font-size:13px;font-weight:500;z-index:999;opacity:0;transition:opacity .2s;pointer-events:none;}
.toast.show{opacity:1;}

/* ── Print ── */
@media print {
  .sidebar,.header,.child-bar,.no-print{display:none!important;}
  .app-body{display:block!important;}
  .main{padding:0!important;}
  .page-panel,.subtab-content{display:block!important;}
  .report-output{display:block!important;box-shadow:none;border:none;padding:0;max-width:100%;}
  body{background:#fff;}
  /* prevent section breaks inside key blocks */
  .report-output>div,
  .report-output .axis-result-row,
  .report-output .radar-grid,
  .report-output .chart-wrap,
  .report-output .brain-block{page-break-inside:avoid;break-inside:avoid;}
  .report-output .section-title{page-break-after:avoid;break-after:avoid;}
}

@media(max-width:900px){
  .sidebar{display:none;}
  .analysis-grid{grid-template-columns:1fr;}
  .radar-grid{grid-template-columns:1fr 1fr;}
  .student-card{grid-template-columns:1fr 1fr;}
  .compare-grid{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- ── Login gate ── -->
<div class="login-gate" id="loginGate">
  <div class="login-box">
    <div class="login-icon">🔒</div>
    <div class="login-title">셀프인지모니터링</div>
    <div class="login-sub">교사용 시스템입니다<br>접근 비밀번호를 입력해 주세요</div>
    <input class="login-input" type="password" id="pwInput" placeholder="비밀번호"
      onkeydown="if(event.key==='Enter') checkPassword()" autofocus>
    <button class="login-btn" onclick="checkPassword()">확인</button>
    <div class="login-error" id="loginError"></div>
  </div>
