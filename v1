// ── Analysis Engine ──
function calcAxisStats(scoresData){
  const sd = typeof scoresData === 'string' ? JSON.parse(scoresData) : (scoresData || {});
  const stats={};
  AXES.forEach(ax=>{
    const vals=STAGES.map(st=>{ const v=sd?.[st]?.[ax.key]; return (v===0||v===1||v===2)?v:0; });
    const mean=vals.reduce((a,b)=>a+b,0)/vals.length;
    const variance=vals.reduce((a,b)=>a+Math.pow(b-mean,2),0)/vals.length;
    stats[ax.key]={mean:mean.toFixed(2),variance:variance.toFixed(2),level:mean>=1.6?'강점':mean>=.8?'발달중':'지원필요',stability:variance<=.4?'안정적':'변동형',vals};
  });
  return stats;
}
function analyze(){
  const axisStats=calcAxisStats(scores);
  const stageTypes={};
  STAGES.forEach(st=>{
    const sorted=AXES.map(ax=>({ax,val:scores[st][ax.key]??0})).sort((a,b)=>b.val-a.val);
    const top=sorted.filter(x=>x.val>=1).slice(0,2);
    stageTypes[st]=top.length?top.map(x=>x.ax.type):['미분류'];
  });
  const sorted=AXES.map(ax=>({ax,mean:parseFloat(axisStats[ax.key].mean)})).sort((a,b)=>b.mean-a.mean);
  return{axisStats,stageTypes,topAxes:sorted.slice(0,2).filter(x=>x.mean>=.8),bottomAxes:sorted.slice(-2).filter(x=>x.mean<.8)};
}

// ── Pentagon SVG ──
function drawRadar(svgEl,values){
  if(!svgEl)return;
  const W=150,H=150,cx=W/2,cy=H/2+2,R=52,n=5;
  const labels=['탐색','조절','사회','신중','감정'];
  function pt(i,r){const a=(Math.PI*2*i/n)-Math.PI/2;return{x:cx+r*Math.cos(a),y:cy+r*Math.sin(a)};}
  let svg='';
  [.33,.67,1].forEach(f=>{
    const pts=Array.from({length:n},(_,i)=>pt(i,R*f)).map(p=>`${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
    svg+=`<polygon points="${pts}" fill="${f===1?'rgba(243,244,246,.7)':'none'}" stroke="#E4E7EC" stroke-width="${f===1?1.5:.8}"/>`;
  });
  for(let i=0;i<n;i++){const p=pt(i,R);svg+=`<line x1="${cx}" y1="${cy}" x2="${p.x.toFixed(1)}" y2="${p.y.toFixed(1)}" stroke="#D1D5DB" stroke-width=".9"/>`;}
  const dataPts=values.map((v,i)=>pt(i,R*Math.min(Math.max(v,0)/2,1)));
  svg+=`<polygon points="${dataPts.map(p=>`${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ')}" fill="#00ac00" fill-opacity=".15" stroke="#00ac00" stroke-width="1.8" stroke-linejoin="round"/>`;
  dataPts.forEach(p=>{svg+=`<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="3" fill="#00ac00" stroke="#fff" stroke-width="1.2"/>`;});
  for(let i=0;i<n;i++){const p=pt(i,R+16);svg+=`<text x="${p.x.toFixed(1)}" y="${p.y.toFixed(1)}" text-anchor="middle" dominant-baseline="middle" font-size="9.5" font-family="'Noto Sans KR',sans-serif" fill="#6B7280" font-weight="600">${labels[i]}</text>`;}
  values.forEach((v,i)=>{if(v>0){const p=dataPts[i];svg+=`<text x="${p.x.toFixed(1)}" y="${(p.y-7).toFixed(1)}" text-anchor="middle" font-size="8" font-family="'Noto Sans KR',sans-serif" fill="#008800" font-weight="700">${v}</text>`;}});
  svgEl.setAttribute('viewBox',`0 0 ${W} ${H}`);svgEl.setAttribute('width','100%');svgEl.setAttribute('height','auto');svgEl.style.maxWidth=W+'px';
  svgEl.innerHTML=svg;
}

// ── Sentences ──
function genAxisSentence(ax,stat){
  const lp={'강점':'전반적으로 높게 나타납니다','발달중':'발달 중인 단계로, 상황에 따라 표현 방식이 다양합니다','지원필요':'아직 명확하게 나타나지 않아 지원이 필요한 단계입니다'};
  return `${ax.name}은(는) ${stat.stability==='안정적'?'고르게':'상황에 따라 변동이 있으며'} ${lp[stat.level]}`;
}
function genSummary(result){
  const{topAxes,bottomAxes,axisStats}=result;let parts=[];
  if(topAxes.length)parts.push(topAxes.map(x=>x.ax.name).join(', ')+' 영역이 활발하게 나타납니다');
  if(bottomAxes.length){const stat=axisStats[bottomAxes[0].ax.key];parts.push(bottomAxes[0].ax.name+'은(는) '+(stat.stability==='안정적'?'고르게':'상황에 따라')+' 발달 중인 단계입니다');}
  return parts.length?parts.join(', '):'전반적인 발달 단계를 관찰 중입니다';
}

// ── Score table ──
function buildTable(){
  const tbody=document.getElementById('scoreBody');tbody.innerHTML='';
  AXES.forEach(ax=>{
    const tr=document.createElement('tr');
    let html=`<td><div class="axis-name">${ax.name}</div><div class="axis-desc">${ax.desc}</div></td>`;
    STAGES.forEach(st=>{
      html+=`<td><div class="score-btn-group">${[0,1,2].map(v=>`<button class="score-btn" id="btn_${st}_${ax.key}_${v}" onclick="setScore('${st}','${ax.key}',${v})">${v}</button>`).join('')}</div></td>`;
    });
    tr.innerHTML=html;tbody.appendChild(tr);
  });
  // ★ 핵심 수정: 테이블 생성 직후 현재 scores 상태를 바로 반영
  applyScoreStyles();
  updateProgress();
}
function applyScoreStyles(){
  STAGES.forEach(st=>AXES.forEach(ax=>[0,1,2].forEach(v=>{
    const btn=document.getElementById(`btn_${st}_${ax.key}_${v}`);
    if(!btn)return;
    btn.className='score-btn';
    if(scores[st][ax.key]===v) btn.classList.add(`active-${v}`);
  })));
}
function setScore(stage,axisKey,val){
  scores[stage][axisKey]=val;
  applyScoreStyles();
  updateProgress();
}
function updateProgress(){
  let filled=0;STAGES.forEach(st=>AXES.forEach(ax=>{if(scores[st][ax.key]!==null)filled++;}));
  document.getElementById('progressBar').style.width=(filled/20*100)+'%';
  document.getElementById('scoreCount').textContent=filled+' / 20 입력됨';
}
function restoreEditTab(){
  document.getElementById('parentGuideText').value=parentGuideText;
  document.getElementById('brainScienceText').value=brainScienceText;
}
function saveParentGuide(val){parentGuideText=val;}
function saveBrainScience(val){brainScienceText=val;}

// ── Analysis render ──
function runAnalysis(){
  analysisResult=analyze();renderAnalysis(analysisResult);
  showPage('write');showSubtab('analysis');
  document.getElementById('analysisPanel').classList.add('visible');
  document.getElementById('analysisEmpty').style.display='none';
}
function renderAnalysis(result){
  const{axisStats,stageTypes}=result;
  document.getElementById('summaryText').textContent=genSummary(result);
  const axisContainer=document.getElementById('axisResultRows');axisContainer.innerHTML='';
  AXES.forEach(ax=>{
    const stat=axisStats[ax.key];
    const lc=stat.level==='강점'?'badge-strong':stat.level==='발달중'?'badge-developing':'badge-support';
    const sc=stat.stability==='안정적'?'badge-stable':'badge-variable';
    const div=document.createElement('div');div.className='axis-result-row';
    div.innerHTML=`<div class="axis-result-header"><span class="axis-result-name">${ax.name}</span><div class="axis-badges"><span class="badge ${lc}">${stat.level}</span><span class="badge ${sc}">${stat.stability}</span><span style="padding:2px 8px;border-radius:20px;font-size:11px;font-weight:600;background:var(--bg);color:var(--text-muted);">평균 ${stat.mean}</span></div></div><div class="axis-auto-text">${genAxisSentence(ax,stat)}</div><textarea class="teacher-input" rows="1" placeholder="✏️ 교사 보완 코멘트..." id="teacherComment_${ax.key}" oninput="saveComment('${ax.key}',this.value)">${teacherComments[ax.key]}</textarea>`;
    axisContainer.appendChild(div);
  });
  const barWrap=document.getElementById('miniBarChart');barWrap.innerHTML='';
  AXES.forEach(ax=>{
    const stat=axisStats[ax.key];const pct=(parseFloat(stat.mean)/2)*100;
    const color=stat.level==='강점'?'#00ac00':stat.level==='발달중'?'#E07B2A':'#DC2626';
    barWrap.innerHTML+=`<div class="mini-bar-row"><span class="mini-bar-label">${ax.short}</span><div class="mini-bar-track"><div class="mini-bar-fill" style="width:${pct}%;background:${color};"></div></div><span class="mini-bar-val">${stat.mean}</span></div>`;
  });
  const radarGrid=document.getElementById('radarGrid');radarGrid.innerHTML='';
  STAGES.forEach(st=>{
    const vals=AXES.map(ax=>scores[st][ax.key]??0);const types=stageTypes[st];
    const card=document.createElement('div');card.className='radar-card';
    const svgId=`rsv_${st.replace(/[가-힣]/g,c=>c.charCodeAt(0).toString(16))}`;
    card.innerHTML=`<div class="radar-card-label">${st}</div><svg id="${svgId}"></svg><div class="radar-type-tags">${types.map(t=>`<span class="type-tag">${t}</span>`).join('')}</div>`;
    radarGrid.appendChild(card);requestAnimationFrame(()=>drawRadar(document.getElementById(svgId),vals));
  });
  const guide=parentGuideText.trim();
  document.getElementById('parentSentences').innerHTML=guide
    ?`<div class="parent-sentence-display" style="white-space:pre-wrap;">${guide}</div>`
    :`<div style="text-align:center;padding:12px;color:var(--text-muted);font-size:13px;">부모 안내 문장이 아직 작성되지 않았습니다. <button class="btn btn-secondary btn-sm" onclick="showSubtab('parent-edit')">✏️ 작성하기</button></div>`;
}
function saveComment(key,val){teacherComments[key]=val;}

// ── Report ──
function showReport(){
  if(!analysisResult)runAnalysis();
  const{axisStats,stageTypes}=analysisResult;
  const name=document.getElementById('childName').value||'아동';
  document.getElementById('rptTitle').textContent=name+' 관찰 리포트';
  document.getElementById('rptMeta').textContent='관찰 교사: '+(document.getElementById('teacherName').value||'—')+'  |  날짜: '+document.getElementById('obsDate').value;
  document.getElementById('rptSummary').textContent=genSummary(analysisResult);
  const rptAxes=document.getElementById('rptAxes');rptAxes.innerHTML='';
  AXES.forEach(ax=>{
    const stat=axisStats[ax.key];
    const lc=stat.level==='강점'?'badge-strong':stat.level==='발달중'?'badge-developing':'badge-support';
    const sc=stat.stability==='안정적'?'badge-stable':'badge-variable';
    const div=document.createElement('div');
    div.style.cssText='margin-bottom:7px;padding:9px 13px;border:1px solid var(--border);border-radius:9px;break-inside:avoid;';
    div.innerHTML=`<div style="display:flex;align-items:center;gap:7px;flex-wrap:wrap;"><span style="font-weight:600;font-size:13px;min-width:68px;">${ax.name}</span><span class="badge ${lc}">${stat.level}</span><span class="badge ${sc}">${stat.stability}</span><span style="font-size:11px;color:var(--text-muted);">avg ${stat.mean}</span><span style="font-size:12px;color:var(--text-secondary);flex:1;">— ${genAxisSentence(ax,stat)}</span></div>${teacherComments[ax.key]?`<div style="font-size:12px;color:var(--warm);margin-top:5px;padding:4px 8px;background:var(--warm-light);border-radius:6px;border-left:2px solid var(--warm);">교사 코멘트: ${teacherComments[ax.key]}</div>`:''}`;
    rptAxes.appendChild(div);
  });
  const rptStages=document.getElementById('rptStages');
  rptStages.innerHTML='<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:9px;width:100%;min-width:0;" id="rptStageGrid"></div>';
  STAGES.forEach(st=>{
    const types=stageTypes[st];const sid=`rRdr_${st.replace(/[가-힣]/g,c=>c.charCodeAt(0).toString(16))}`;
    const div=document.createElement('div');
    div.style.cssText='text-align:center;padding:11px 8px;background:var(--bg);border:1px solid var(--border);border-radius:9px;min-width:0;overflow:hidden;break-inside:avoid;';
    div.innerHTML=`<div style="font-size:11px;font-weight:600;color:var(--text-secondary);margin-bottom:5px;">${st}</div><svg id="${sid}" style="max-width:100%;height:auto;display:block;margin:0 auto;"></svg><div style="margin-top:5px;display:flex;flex-wrap:wrap;gap:3px;justify-content:center;">${types.map(t=>`<span style="display:inline-block;background:#1A1A1A;color:#fff;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:600;">${t}</span>`).join('')}</div>`;
    document.getElementById('rptStageGrid').appendChild(div);
    requestAnimationFrame(()=>drawRadar(document.getElementById(sid),AXES.map(ax=>scores[st][ax.key]??0)));
  });
  const guide=parentGuideText.trim();
  document.getElementById('rptParent').innerHTML=guide
    ?`<div style="font-size:13px;color:var(--text-secondary);line-height:1.85;padding:11px 15px;background:var(--warm-light);border-radius:8px;border-left:2.5px solid var(--warm);white-space:pre-wrap;break-inside:avoid;">${guide}</div>`
    :`<div style="color:var(--text-muted);font-size:13px;padding:4px 0;">부모 안내 문장이 아직 작성되지 않았습니다.</div>`;
  // Weekly trend in report
  const rptTrend=document.getElementById('rptTrendSection');
  if(currentChildId&&observationsList.length>=2){
    const tLabels=observationsList.map(r=>{const d=new Date(r.observed_at);const start=new Date(d.getFullYear(),0,1);const week=Math.ceil(((d-start)/86400000+start.getDay()+1)/7);return `${d.getMonth()+1}/${d.getDate()} (${week}주차)`;});
    const tDatasets=AXES.map((ax,i)=>({label:ax.name,data:observationsList.map(r=>parseFloat(calcAxisStats(r.scores)[ax.key].mean)),borderColor:AXIS_COLORS[i],backgroundColor:AXIS_COLORS[i]+'33',tension:.35,pointRadius:4,borderWidth:2,fill:false}));
    const cid='rptTrendC_'+Date.now();
    rptTrend.innerHTML=`<div style="margin-bottom:16px;break-inside:avoid;"><div class="section-title">⑤ 주별 발달축 추이</div><div style="background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:14px 16px;"><canvas id="${cid}" style="max-height:240px;"></canvas></div></div>`;
    requestAnimationFrame(()=>{const ctx2=document.getElementById(cid);if(ctx2)new Chart(ctx2.getContext('2d'),{type:'line',data:{labels:tLabels,datasets:tDatasets},options:{responsive:true,scales:{y:{min:0,max:2,ticks:{stepSize:.5}},x:{ticks:{font:{size:10}}}},plugins:{legend:{position:'bottom'}}}});});
  } else rptTrend.innerHTML='';
  const brain=brainScienceText.trim();
  document.getElementById('rptBrainSection').innerHTML=brain?`<div class="brain-block break-inside:avoid;"><div class="brain-block-title">🧠 이달의 뇌과학 지식 한스푼</div><div class="brain-block-text">${brain.replace(/\n/g,'<br>')}</div></div>`:'';
  document.getElementById('reportOutput').classList.add('visible');
  document.getElementById('reportEmpty').style.display='none';
  showPage('write');showSubtab('report');
}

// ── Navigation ──
let currentPage='write';
function showPage(id){
  document.querySelectorAll('.page-panel').forEach(p=>p.classList.remove('active'));
  const target=document.getElementById('page-'+id);
  if(target)target.classList.add('active');
  // sidebar nav
  document.querySelectorAll('.nav-item').forEach(b=>b.classList.remove('active'));
  const navWrite=['input','parent-edit','analysis','report'];
  if(navWrite.includes(id)||id==='write'){
    // highlight current subtab nav
  } else {
    const nav=document.getElementById('nav-'+id);
    if(nav)nav.classList.add('active');
  }
  currentPage=id;
}

function showSubtab(id){
  // show write page first
  showPage('write');
  document.querySelectorAll('.subtab-content').forEach(t=>t.classList.remove('active'));
  const target=document.getElementById('subtab-'+id);
  if(target)target.classList.add('active');
  document.querySelectorAll('.subtab-btn').forEach(b=>b.classList.remove('active'));
  const stab=document.getElementById('stab-'+id);
  if(stab)stab.classList.add('active');
  // sidebar
  document.querySelectorAll('.nav-item').forEach(b=>b.classList.remove('active'));
  const nav=document.getElementById('nav-'+id);
  if(nav)nav.classList.add('active');
}

function resetAll(){
  if(!confirm('현재 입력값을 모두 초기화하시겠습니까?\n(저장된 DB 기록은 유지됩니다)'))return;
  STAGES.forEach(s=>AXES.forEach(a=>{scores[s][a.key]=null;}));
  AXES.forEach(a=>{teacherComments[a.key]='';});
  parentGuideText='';brainScienceText='';analysisResult=null;
  document.getElementById('obsDate').value=new Date().toISOString().slice(0,10);
  document.getElementById('teacherName').value='';
  document.getElementById('analysisPanel').classList.remove('visible');
  document.getElementById('analysisEmpty').style.display='';
  document.getElementById('reportOutput').classList.remove('visible');
  document.getElementById('reportEmpty').style.display='';
  buildTable();restoreEditTab();updateProgress();showSubtab('input');
}

function showToast(msg,duration=2500){
  const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),duration);
}
</script>
