    item.className='history-item expanded'; // expanded by default
    item.dataset.obsId=obs.id;

    // badge row
    const badges=AXES.map(ax=>{
      const s=axisStats[ax.key];
      const bg=s.level==='강점'?'var(--accent-light)':s.level==='발달중'?'#FEF3E7':'var(--danger-light)';
      const cl=s.level==='강점'?'var(--accent-dark)':s.level==='발달중'?'#B45309':'var(--danger)';
      return `<span style="padding:2px 7px;border-radius:10px;font-size:10px;font-weight:600;background:${bg};color:${cl};">${ax.short} ${s.mean}</span>`;
    }).join('');

    // score preview table (always visible)
    const obsScores = typeof obs.scores === 'string' ? JSON.parse(obs.scores) : (obs.scores || {});
    const scoreRows=AXES.map(ax=>{
      const cells=STAGES.map(st=>{
